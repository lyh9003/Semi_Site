# Supabase (Supabase 대시보드 > Settings > API에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://zpfcxfzxqpprtcjmzosc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here  # 임포트 스크립트 전용

# 토스페이먼츠 (https://developers.tosspayments.com 에서 발급)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...   # 클라이언트 키 (공개)
TOSS_SECRET_KEY=test_sk_...               # 시크릿 키 (서버 전용, 절대 공개 금지)

# 앱 URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
